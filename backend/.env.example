# Database (development: sqlite, production: postgres / MariaDB)
DATABASE_URL=sqlite+aiosqlite:///./app.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/did
# MariaDB (MySQL 호환) — 로컬 설치 시
# DATABASE_URL=mysql+asyncmy://user:password@localhost:3306/did
# Railway MariaDB:
# - API 서비스에 DATABASE_URL 을 직접 넣거나, MariaDB의 MYSQL_URL 만 있으면 앱이 DATABASE_URL 로 자동 반영함
# - 수동 예시(비밀번호 특수문자는 URL 인코딩): DATABASE_URL=mysql+asyncmy://USER:PASSWORD@HOST:PORT/DATABASE
# 로컬에서 MariaDB를 직접 띄운 경우 위 mysql+asyncmy URL 로 호스트·DB명·계정을 맞춤.

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: file storage (local uploads if not set)
UPLOAD_DIR=./uploads
# MEDIA_BASE_URL=http://localhost:8000/media

# Cloudflare R2 (모두 설정 시 미디어 업로드는 버킷에만 저장, 키: media/image|video|html/...)
# R2 대시보드: S3 API 엔드포인트·액세스 키·퍼블릭 URL(또는 R2.dev) 확인
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=did
# Railway 등에서는 버킷 이름을 R2_BUCKET_NAME 으로만 넣는 경우가 있음 (둘 중 하나)
# R2_BUCKET_NAME=chowon-contents
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# 디바이스 등록 시 플레이어가 입력해야 할 인증코드 (회사에서만 공유)
REGISTRATION_AUTH_CODE=dev1234

# DDNS/외부 접속 시 CORS 허용 출처 (쉼표 구분). CMS·플레이어 접속 URL을 넣으세요.
# CORS_ORIGINS_EXTRA=https://noteserver.iptime.org:5173,https://noteserver.iptime.org:5174

# last_seen 갱신 없이 이 시간(초)이 지나면 CMS 디바이스 목록에 offline 표시 (기본 420=7분, 스케줄 폴링 5분보다 김)
# DEVICE_OFFLINE_AFTER_SECONDS=420
