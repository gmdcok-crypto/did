# Database (development: sqlite, production: postgres / MariaDB)
DATABASE_URL=sqlite+aiosqlite:///./app.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/did
# MariaDB (MySQL 호환) — 로컬 설치 시
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/did
# Railway MariaDB: 서비스의 Variables(또는 Connect)에서 호스트·포트·유저·비번·DB명 확인 후 아래 형식(비밀번호 특수문자는 URL 인코딩)
# DATABASE_URL=mysql+aiomysql://USER:PASSWORD@HOST:PORT/DATABASE
# Docker Compose 사용 시: backend는 docker-compose.yml에서 DATABASE_URL 자동 설정 (MariaDB 서비스명 호스트명: mariadb)

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: file storage (local uploads if not set)
UPLOAD_DIR=./uploads
# MEDIA_BASE_URL=http://localhost:8000/media

# 디바이스 등록 시 플레이어가 입력해야 할 인증코드 (회사에서만 공유)
REGISTRATION_AUTH_CODE=dev1234

# DDNS/외부 접속 시 CORS 허용 출처 (쉼표 구분). CMS·플레이어 접속 URL을 넣으세요.
# CORS_ORIGINS_EXTRA=https://noteserver.iptime.org:5173,https://noteserver.iptime.org:5174
